<script>
        // Simple Micro-interaction for inputs
        const inputs = document.querySelectorAll('input');
        inputs.forEach(input => {
            input.addEventListener('focus', () => {
                input.parentElement.parentElement.classList.add('border-primary');
            });
            input.addEventListener('blur', () => {
                input.parentElement.parentElement.classList.remove('border-primary');
            });
        });

        // Numeric input only logic
        inputs.forEach(input => {
            input.addEventListener('input', (e) => {
                let value = e.target.value.replace(/[^0-9.]/g, '');
                // Allow only one dot
                const dots = value.match(/\./g);
                if (dots && dots.length > 1) {
                    value = value.slice(0, value.lastIndexOf('.'));
                }
                e.target.value = value;
            });
        });
