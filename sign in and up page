</p>
</footer>
<!-- END: Footer -->
</main>
<!-- END: Main Container -->
<script data-purpose="password-visibility-logic">
    // Small script to handle the eye toggle interactivity
    document.querySelectorAll('[data-purpose="toggle-password"]').forEach(button => {
      button.addEventListener('click', () => {
        const input = button.parentElement.querySelector('input');
        if (input.type === 'password') {
          input.type = 'text';
        } else {
          input.type = 'password';
        }
      });
    });
  </script>


</body></html>

