<!DOCTYPE html><html lang="en"><head>
<meta charset="utf-8">
<meta content="width=device-width, initial-scale=1.0" name="viewport">
<title>FanBridge Wallet Screen</title>
<!-- BEGIN: Tailwind CSS Integration -->
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            brandBlue: '#0A2540',
            brandLightBlue: '#1E40AF',
            positiveGreen: '#10B981',
            negativeRed: '#EF4444',
            bgGray: '#F9FAFB',
          }
        }
      }
    }
  </script>
<!-- END: Tailwind CSS Integration -->
<style data-purpose="custom-layout">
    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
      background-color: #f3f4f6;
    }
    .status-bar-height { height: 44px; }
    .bottom-nav-height { height: 84px; }
    .hide-scrollbar::-webkit-scrollbar { display: none; }
    .hide-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
  </style>
</head>
<body class="flex justify-center items-center min-h-screen">
<!-- BEGIN: Mobile Container (iOS Style) -->
<main class="w-full max-w-[390px] h-[844px] bg-white shadow-2xl relative flex flex-col overflow-hidden">
<!-- BEGIN: Top Status Bar Space -->

<!-- END: Top Status Bar Space -->
<!-- BEGIN: Header Section -->
<header class="px-6 py-4 flex justify-between items-center" data-purpose="screen-header">
<div class="flex items-center gap-2">
<h1 class="text-2xl font-bold text-gray-900">Wallet</h1>
<button class="text-gray-400">
<!-- Eye icon for hide/show balance -->
<svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
<path d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path>
<path d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path>
</svg>
</button>
</div>
<button class="p-2 text-gray-600">
<!-- Gear icon -->
<svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
<path d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path>
<path d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path>
</svg>
</button>
</header>
<!-- END: Header Section -->
<!-- BEGIN: Balance and Actions Card -->
<div class="px-5">
<div class="bg-brandBlue rounded-3xl p-6 text-white shadow-lg relative overflow-hidden" data-purpose="balance-card">
<!-- Decorative abstract shape background (optional, mimicking UI) -->
<div class="absolute -right-10 -top-10 w-32 h-32 bg-white/5 rounded-full blur-2xl"></div>
<p class="text-sm opacity-80 mb-1">Total Balance</p>
<div class="flex justify-between items-center mb-8">
<div>
<span class="text-4xl font-bold">128.50</span>
<span class="text-xl font-medium ml-1">USDT</span>
<p class="text-xs opacity-60 mt-1">≈ $128.50</p>
</div>
<!-- Tether Logo Placeholder -->
<div class="w-12 h-12 bg-emerald-500 rounded-full flex items-center justify-center border-2 border-emerald-400">
<span class="font-bold text-xl">₮</span>
</div>
</div>
<!-- Action Buttons -->
<div class="grid grid-cols-4 gap-2 pt-4 border-t border-white/10" data-purpose="wallet-actions">
<button class="flex flex-col items-center gap-2 group">
<div class="w-12 h-12 bg-white/10 rounded-full flex items-center justify-center group-active:scale-95 transition-transform">
<svg class="h-6 w-6 transform rotate-45" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
<path d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path>
</svg>
</div>
<span class="text-[11px]">Send</span>
</button>
<button class="flex flex-col items-center gap-2 group">
<div class="w-12 h-12 bg-white/10 rounded-full flex items-center justify-center group-active:scale-95 transition-transform">
<svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
<path d="M19 14l-7 7m0 0l-7-7m7 7V3" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path>
</svg>
</div>
<span class="text-[11px]">Receive</span>
</button>
<button class="flex flex-col items-center gap-2 group">
<div class="w-12 h-12 bg-white/10 rounded-full flex items-center justify-center group-active:scale-95 transition-transform">
<svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
<path d="M12 4v1m6 11h2m-6 0h-2v4m0-11v3m0 0h.01M12 12h4.01M16 20h4M4 12h4m12 0h.01M5 8h2a1 1 0 001-1V5a1 1 0 00-1-1H5a1 1 0 00-1 1v2a1 1 0 001 1zm12 0h2a1 1 0 001-1V5a1 1 0 00-1-1h-2a1 1 0 00-1 1v2a1 1 0 001 1zM5 20h2a1 1 0 001-1v-2a1 1 0 00-1-1H5a1 1 0 00-1 1v2a1 1 0 001 1z" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path>
</svg>
</div>
<span class="text-[11px]">Scan</span>
</button>
<button class="flex flex-col items-center gap-2 group">
<div class="w-12 h-12 bg-white/10 rounded-full flex items-center justify-center group-active:scale-95 transition-transform">
<svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
<path d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path>
</svg>
</div>
<span class="text-[11px]">History</span>
</button>
</div>
</div>
</div>
<!-- END: Balance and Actions Card -->
<!-- BEGIN: Transactions Section -->
<div class="mt-8 flex-1 flex flex-col overflow-hidden px-6" data-purpose="transaction-list">
<div class="flex justify-between items-center mb-4">
<h2 class="text-lg font-bold text-gray-900">Recent Transactions</h2>
<button class="text-sm font-medium text-blue-600">See all</button>
</div>
<!-- Transaction Items Container -->
<div class="flex-1 overflow-y-auto space-y-5 hide-scrollbar pb-24">
<!-- Transaction Item -->
<div class="flex justify-between items-center" data-purpose="transaction-item">
<div class="flex items-center gap-4">
<div class="w-10 h-10 rounded-full bg-emerald-50 flex items-center justify-center border border-emerald-100">
<span class="text-emerald-500 font-bold">₮</span>
</div>
<div>
<p class="font-semibold text-sm text-gray-800">Received from Alex</p>
<p class="text-xs text-gray-400">Today</p>
</div>
</div>
<p class="text-sm font-bold text-positiveGreen">+25.00 USDT</p>
</div>
<!-- Transaction Item -->
<div class="flex justify-between items-center" data-purpose="transaction-item">
<div class="flex items-center gap-4">
<div class="w-10 h-10 rounded-full bg-blue-50 flex items-center justify-center border border-blue-100">
<!-- Trophy Icon -->
<svg class="h-5 w-5 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
<path d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path>
</svg>
</div>
<div>
<p class="font-semibold text-sm text-gray-800">Bet Won</p>
<p class="text-xs text-gray-400">Yesterday</p>
</div>
</div>
<p class="text-sm font-bold text-positiveGreen">+50.00 USDT</p>
</div>
<!-- Transaction Item -->
<div class="flex justify-between items-center" data-purpose="transaction-item">
<div class="flex items-center gap-4">
<div class="w-10 h-10 rounded-full bg-gray-100 flex items-center justify-center border border-gray-200">
<!-- User Icon -->
<svg class="h-5 w-5 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
<path d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path>
</svg>
</div>
<div>
<p class="font-semibold text-sm text-gray-800">Sent to Priya</p>
<p class="text-xs text-gray-400">May 28</p>
</div>
</div>
<p class="text-sm font-bold text-gray-800">-10.00 USDT</p>
</div>
<!-- Transaction Item -->
<div class="flex justify-between items-center" data-purpose="transaction-item">
<div class="flex items-center gap-4">
<div class="w-10 h-10 rounded-full bg-blue-50 flex items-center justify-center border border-blue-100">
<!-- Ticket Icon -->
<svg class="h-5 w-5 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
<path d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path>
</svg>
</div>
<div>
<p class="font-semibold text-sm text-gray-800">Ticket Purchase</p>
<p class="text-xs text-gray-400">May 26</p>
</div>
</div>
<p class="text-sm font-bold text-gray-800">-45.00 USDT</p>
</div>
</div>
</div>
<!-- END: Transactions Section -->
<!-- BEGIN: Bottom Navigation -->
<nav class="bottom-nav-height bg-white border-t border-gray-100 flex items-start justify-around px-2 pt-3 absolute bottom-0 w-full z-10" data-purpose="main-navigation">
<div class="flex flex-col items-center gap-1 group">
<svg class="h-6 w-6 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
<path d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path>
</svg>
<span class="text-[10px] text-gray-400">Home</span>
</div>
<div class="flex flex-col items-center gap-1 group">
<svg class="h-6 w-6 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
<path d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path>
</svg>
<span class="text-[10px] text-gray-400">Marketplace</span>
</div>
<!-- Central Plus Button -->
<div class="relative -top-8">
<button class="w-14 h-14 bg-blue-600 rounded-full flex items-center justify-center shadow-lg text-white">
<svg class="h-8 w-8" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
<path d="M12 6v6m0 0v6m0-6h6m-6 0H6" stroke-linecap="round" stroke-linejoin="round" stroke-width="3"></path>
</svg>
</button>
</div>
<div class="flex flex-col items-center gap-1 group">
<svg class="h-6 w-6 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
<path d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path>
</svg>
<span class="text-[10px] text-gray-400">Chats</span>
</div>
<div class="flex flex-col items-center gap-1 group">
<svg class="h-6 w-6 text-blue-600" fill="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
<path d="M3 10h18v10a2 2 0 01-2 2H5a2 2 0 01-2-2V10z"></path>
<path clip-rule="evenodd" d="M3 4a2 2 0 012-2h14a2 2 0 012 2v4H3V4zm2 2h14V4H5v2z" fill-rule="evenodd"></path>
</svg>
<span class="text-[10px] font-bold text-blue-600">Wallet</span>
</div>
<!-- iOS Home Indicator -->
<div class="absolute bottom-1 w-32 h-1 bg-gray-200 rounded-full left-1/2 -translate-x-1/2"></div>
</nav>
<!-- END: Bottom Navigation -->
</main>
<!-- END: Mobile Container -->


</body></html>
