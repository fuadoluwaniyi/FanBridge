<script data-purpose="countdown-logic">
    // Simple script to animate the seconds in the challenge live widget
    let seconds = 45;
    const secEl = document.querySelector('[data-purpose="challenge-widget-live"] .text-center:last-child span');
    
    if(secEl) {
      setInterval(() => {
        seconds--;
        if(seconds < 0) seconds = 59;
        secEl.textContent = seconds.toString().padStart(2, '0');
      }, 1000);
    }
  </script>


